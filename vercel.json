{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "admin.html",
          "style.css",
          "script.js",
          "*.png",
          "*.jpg",
          "*.jpeg"
        ]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/admin",   "dest": "server.js" },
    { "src": "/(.*)",    "dest": "server.js" }
  ]
}
